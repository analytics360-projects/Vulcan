# ── People Data Labs (PDL) ──
# 1. Ir a https://www.peopledatalabs.com/signup
# 2. Crear cuenta y obtener API key desde el dashboard
# 3. Free tier disponible + pay-as-you-go
# 4. Rate limit: 10 requests/minuto (default)
# Docs: https://docs.peopledatalabs.com/docs/person-search-api
PDL_API_KEY=

# ══════════════════════════════════════════════════
# OSINT API Keys — Instrucciones para obtener cada una
# ══════════════════════════════════════════════════

# ── Twitter/X ──
# 1. Ir a https://developer.x.com/en/portal/dashboard
# 2. Crear un proyecto y una app
# 3. En "Keys and Tokens" generar un Bearer Token
# 4. Plan gratuito: 500K tweets/mes de lectura
TWITTER_BEARER_TOKEN=

# ── Instagram (Meta Graph API) ──
# 1. Ir a https://developers.facebook.com/
# 2. Crear una app tipo "Business"
# 3. Agregar el producto "Instagram Basic Display API" o "Instagram Graph API"
# 4. Generar un token de acceso de larga duracion
# NOTA: Solo funciona con cuentas Business/Creator de Instagram
INSTAGRAM_ACCESS_TOKEN=

# ── Telegram ──
# 1. Ir a https://my.telegram.org/auth
# 2. Iniciar sesion con tu numero de telefono
# 3. Ir a "API development tools"
# 4. Crear una nueva aplicacion
# 5. Copiar el api_id y api_hash
# GRATIS - sin limite de uso
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Reddit ──
# 1. Ir a https://www.reddit.com/prefs/apps
# 2. Click en "create another app..."
# 3. Seleccionar "script"
# 4. Copiar el client_id (debajo del nombre de la app) y el secret
# GRATIS - 60 requests/minuto
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── NumVerify (validacion de telefonos) ──
# 1. Ir a https://numverify.com/
# 2. Registrarse (plan gratuito: 100 requests/mes)
# 3. Copiar el API Access Key del dashboard
# Planes de pago: desde $14.99/mes para 5,000 requests
NUMVERIFY_API_KEY=

# ── Hunter.io (verificacion de emails) ──
# 1. Ir a https://hunter.io/users/sign_up
# 2. Registrarse (plan gratuito: 25 busquedas/mes + 50 verificaciones/mes)
# 3. Ir a https://hunter.io/api-keys y copiar la API Key
# Planes de pago: desde $34/mes para 500 busquedas
HUNTER_API_KEY=

# ── Have I Been Pwned (data breaches) ──
# 1. Ir a https://haveibeenpwned.com/API/Key
# 2. Comprar una API key ($3.50 USD/mes)
# 3. Es de pago, no hay plan gratuito para la API
HIBP_API_KEY=
